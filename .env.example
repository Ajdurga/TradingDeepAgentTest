# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4  # or gpt-4-turbo, gpt-3.5-turbo

# Optional: Robinhood MCP Configuration (read-only)
ROBINHOOD_MCP_ENABLED=false
ROBINHOOD_MCP_SERVER_URL=http://localhost:8000

# Agent Configuration
MAX_ITERATIONS=20
WORKSPACE_DIR=./workspace
MEMORY_DIR=./workspace/memory

# Risk Configuration
MAX_POSITION_RISK_PERCENT=2.0
DEFAULT_RISK_TOLERANCE=medium

# Logging
LOG_LEVEL=INFO